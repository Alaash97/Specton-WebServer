PORT=8080
RATE_LIMIT_WINDOW_MS=2000
RATE_LIMIT_MAX_ACTIONS=1
HEARTBEAT_INTERVAL_MS=30000

# Optional S3-compatible storage for runtime PCG map tiles.
# Leave MINIO_ENDPOINT empty to use in-memory dev storage.
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=specton-session-assets
MINIO_REGION=us-east-1
# Optional public/CDN URL for direct browser tile reads.
# For path-style MinIO this is usually:
# https://your-minio-host/specton-session-assets
MINIO_PUBLIC_BASE_URL=
# Keep false for private buckets. The server will redirect tile requests to
# short-lived presigned MinIO URLs instead of exposing permanent public paths.
MINIO_PUBLIC_READS=false
MINIO_PRESIGNED_GET_EXPIRY_SECONDS=300
# Reliable default: the websocket server reads private MinIO objects and returns
# image bytes. Set true only after MinIO/browser redirects are verified.
SESSION_ASSET_REDIRECTS=false
MAP_TILE_CACHE_LIMIT_MB=128
CLEANUP_SESSION_ASSETS_ON_STARTUP=false
LOG_SESSION_ASSET_REQUESTS=false
